<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup/transfer rules. We exclude everything from both cloud
  backup and device-to-device transfer because the settings DataStore holds the
  server URL with its `?token=` secret + `&fp=` cert pin, and the Room chat DB
  holds conversation content. allowBackup="false" covers pre-12; this covers 12+.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
