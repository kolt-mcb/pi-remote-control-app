<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>

        <!-- ADB/test broadcast receiver. Debug builds only — release APKs do not
             register this, so the actions cannot be triggered from other apps.
             Gated by the signature|privileged DUMP permission so that even in a
             sideloaded debug build only the adb shell (which holds DUMP) can drive
             it — a co-installed app cannot inject prompts or repoint the connection.
             `adb shell am broadcast ...` still works. -->
        <receiver android:name=".test.TestReceiver"
            android:exported="true"
            android:permission="android.permission.DUMP">
            <intent-filter>
                <action android:name="com.piremote.test.CONNECT" />
                <action android:name="com.piremote.test.SEND_PROMPT" />
                <action android:name="com.piremote.test.SEND_STEER" />
                <action android:name="com.piremote.test.SEND_FOLLOWUP" />
                <action android:name="com.piremote.test.DISCONNECT" />
                <action android:name="com.piremote.test.CLEAR_HISTORY" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
